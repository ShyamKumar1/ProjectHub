{
  "name": "projecthub",
  "private": true,
  "version": "1.0.0",
  "description": "Project Dashboard & Collaboration Hub",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "vercel-build": "turbo build --filter=@projecthub/web",
    "lint": "turbo lint",
    "test": "turbo test",
    "clean": "turbo clean",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\""
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "prettier": "^3.2.0",
    "turbo": "^2.0.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "npm@10.2.4"
}

# === ProjectHub Environment Variables ===

# --- Database ---
# PostgreSQL connection (used by Fastify backend)
DATABASE_URL=postgresql://projecthub:projecthub@localhost:5433/projecthub
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=projecthub
POSTGRES_USER=projecthub
POSTGRES_PASSWORD=projecthub

# --- Auth / JWT ---
JWT_SECRET=change-this-to-a-random-64-char-string
COOKIE_SECRET=change-this-to-a-random-string

# --- OAuth ---
# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id

# GitHub OAuth
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
NEXT_PUBLIC_GITHUB_CLIENT_ID=your-github-client-id

# GitHub API Token (optional, for higher rate limits)
GITHUB_TOKEN=

# --- API Configuration ---
NEXT_PUBLIC_API_URL=http://localhost:4000
CORS_ORIGIN=http://localhost:3000
PORT=4000
HOST=0.0.0.0

# --- Vercel (for production deployment) ---
VERCEL=1
